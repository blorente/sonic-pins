# TODO(bazel-ready): This assumes this repo is a submodule of sonic-buildimage.
common --registry=file://%workspace%/../../../tools/bazel/registry
common --registry=https://bcr.bazel.build

common --cxxopt='-std=c++17'
common --host_cxxopt='-std=c++17'

# To allow loops with int and comparison against a .size() that's size_t.
common --copt='-Wno-error=sign-compare'
common --host_copt='-Wno-error=sign-compare'

common --test_output=errors
common --features=external_include_paths
common --per_file_copt=external/.*@-w
common --per_file_copt=.*protobuf.*@-w


# Don’t want to push a rules author to update their deps if not needed.
# https://bazel.build/reference/command-line-reference#flag--check_direct_dependencies
common --check_direct_dependencies=off
